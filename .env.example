// Variables de entorno de Supabase
// Crea un archivo .env.local con estas variables:
//
// EXPO_PUBLIC_SUPABASE_URL=https://xxxx.supabase.co
// EXPO_PUBLIC_SUPABASE_ANON_KEY=eyJhbGci...

// Google Calendar (OAuth)
// Obtén estos IDs en Google Cloud Console > APIs & Services > Credenciales
// iOS: crea un cliente "Aplicación iOS" con el bundle ID com.jorgebuitragofcv.manicuristapp
// Android: crea un cliente "Aplicación Android" con el SHA-1 y el package name
//
// EXPO_PUBLIC_GOOGLE_IOS_CLIENT_ID=XXXX.apps.googleusercontent.com
// EXPO_PUBLIC_GOOGLE_ANDROID_CLIENT_ID=XXXX.apps.googleusercontent.com
