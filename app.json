{
  "expo": {
    "name": "ManicuristApp",
    "slug": "manicuristapp",
    "version": "1.0.0",
    "scheme": "manicuristapp",
    "orientation": "default",
    "plugins": [
      "expo-router",
      "expo-system-ui",
      [
        "expo-splash-screen",
        {
          "backgroundColor": "#fff9fc",
          "resizeMode": "contain",
          "image": "./assets/manicuristapp-icon.png"
        }
      ],
      [
        "expo-notifications",
        {
          "icon": "./assets/manicuristapp-icon.png",
          "color": "#c084fc",
          "sounds": []
        }
      ],
      "expo-secure-store",
      "@react-native-community/datetimepicker",
      "expo-web-browser",
      "expo-localization",
      [
        "expo-media-library",
        {
          "photosPermission": "Permitir el acceso a tu galería para guardar fotos.",
          "savePhotosPermission": "Permitir guardar fotos en tu galería.",
          "isAccessMediaLocationEnabled": true,
          "android": {
            "permissions": [
              "READ_MEDIA_IMAGES",
              "READ_MEDIA_VIDEO",
              "ACCESS_MEDIA_LOCATION",
              "WRITE_EXTERNAL_STORAGE"
            ]
          }
        }
      ]
    ],
    "icon": "./assets/manicuristapp-icon.png",
    "userInterfaceStyle": "automatic",
    "backgroundColor": "#fff9fc",
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.jorgebuitragofcv.manicuristapp",
      "infoPlist": {
        "CFBundleURLTypes": [
          {
            "CFBundleURLSchemes": [
              "com.googleusercontent.apps.665407645505-bgs49epshlgma9t45a1or4kl89elrhus"
            ]
          },
          {
            "CFBundleURLSchemes": [
              "com.googleusercontent.apps.665407645505-bgs49epshlgma9t45a1or4kl89elrhus"
            ]
          }
        ]
      }
    },
    "android": {
      "package": "com.jorgebuitragofcv.manicuristapp",
      "intentFilters": [
        {
          "action": "VIEW",
          "autoVerify": true,
          "data": [
            {
              "scheme": "com.googleusercontent.apps.665407645505-s8goe8lq2jcbu72fdkcuj2mqsgnjt7g2"
            }
          ],
          "category": ["BROWSABLE", "DEFAULT"]
        }
      ],
      "adaptiveIcon": {
        "backgroundColor": "#FFFFFF",
        "foregroundImage": "./assets/manicuristapp-icon-foreground.png"
      },
      "predictiveBackGestureEnabled": false,
      "permissions": [
        "android.permission.READ_EXTERNAL_STORAGE",
        "android.permission.WRITE_EXTERNAL_STORAGE",
        "android.permission.READ_MEDIA_VISUAL_USER_SELECTED",
        "android.permission.ACCESS_MEDIA_LOCATION",
        "android.permission.READ_MEDIA_IMAGES",
        "android.permission.READ_MEDIA_VIDEO",
        "android.permission.READ_MEDIA_AUDIO",
        "android.permission.READ_EXTERNAL_STORAGE",
        "android.permission.WRITE_EXTERNAL_STORAGE",
        "android.permission.READ_MEDIA_VISUAL_USER_SELECTED",
        "android.permission.ACCESS_MEDIA_LOCATION",
        "android.permission.READ_MEDIA_IMAGES",
        "android.permission.READ_MEDIA_VIDEO",
        "android.permission.READ_MEDIA_AUDIO"
      ]
    },
    "web": {
      "favicon": "./assets/manicuristapp-icon.png"
    },
    "extra": {
      "router": {},
      "eas": {
        "projectId": "09ac53c1-59af-4b91-80c7-9cb35ea3409f"
      }
    },
    "runtimeVersion": {
      "policy": "appVersion"
    },
    "updates": {
      "url": "https://u.expo.dev/09ac53c1-59af-4b91-80c7-9cb35ea3409f"
    }
  }
}
